// SeedLand · V — AI 视频社群平台数据模型
// 详细文档：https://pris.ly/d/prisma-schema
//
// 设计原则
// 1. 所有主键使用 cuid。
// 2. 所有表都有 createdAt；可被修改的表带 updatedAt。
// 3. 用户密码只保存 passwordHash。
// 4. Like / Bookmark 通过可空外键实现多态（Post / Work），Like 额外支持 Comment。
// 5. Conversation 走 N:N 参与者表，可直接复用为一对一私信。
// 6. 字段命名 camelCase，库列名 snake_case。
// 7. 商业化扩展（会员、订单、工作流市场、企业账号）已预留 stub 模型。

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═════════════════════════════════════════════════════════════════
//                              enums
// ═════════════════════════════════════════════════════════════════

enum Role {
  USER
  MOD
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum WorkModel {
  SEEDANCE_2_0
  SEEDANCE_FAST
}

enum WorkMode {
  TEXT_TO_VIDEO
  IMAGE_TO_VIDEO
  FIRST_LAST_FRAME
  MULTI_REFERENCE
}

enum WorkCategory {
  AI_COMIC        // AI 漫剧
  AI_DRAMA        // AI 短剧
  AI_ANIMATION    // AI 动画
  DIGITAL_HUMAN   // 数字人视频
  ECOMMERCE_AD    // 电商广告视频
  PRODUCT_SHOW    // 产品展示视频
  KNOWLEDGE       // 知识讲解视频
  STORY           // 故事类视频
  EXPERIMENT      // 实验短片
}

enum CollaborationType {
  LOOKING_FOR // 我正在找
  OFFERING    // 我可以提供
}

enum CollaborationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum CollaborationCategory {
  AI_VIDEO_TEAM      // 找 AI 视频制作团队
  AI_COMIC_CREATOR   // 找 AI 漫剧创作者
  AI_DRAMA_TEAM      // 找 AI 短剧团队
  DIGITAL_HUMAN      // 找数字人制作
  PROMPT_ENGINEER    // 找提示词工程师
  COMFYUI_WORKFLOW   // 找 ComfyUI 工作流搭建
  EDITOR             // 找剪辑师
  COFOUNDER          // 找联合创始人
  INVEST_BIZ         // 找投资 / 商务合作
  OTHER              // 其他
}

enum CollaborationWorkMode {
  PROJECT    // 项目制
  FULL_TIME  // 全职
  PART_TIME  // 兼职
  FREELANCE  // 外包
  EQUITY     // 合伙 / 股权
  ONE_OFF    // 一次性单子
}

enum CollaborationLocation {
  REMOTE  // 远程
  ONSITE  // 线下
  HYBRID  // 远程 + 线下
}

enum ToolPricing {
  FREE
  FREEMIUM
  PAID
}

enum PostType {
  DISCUSSION    // 普通交流
  SHOWCASE      // 作品展示
  COLLABORATION // 项目合作
  TOOL_RECOMMEND // 工具推荐
  TUTORIAL      // 教程经验
  QUESTION      // 提问求助
  NEWS          // 行业资讯
}

enum NotificationType {
  POST_REPLY
  COMMENT_REPLY
  POST_LIKE
  WORK_LIKE
  COMMENT_LIKE
  BOOKMARK
  MENTION
  COLLAB_REPLY
  MESSAGE
  SYSTEM
}

enum ReportTargetType {
  USER
  POST
  COMMENT
  WORK
  COLLABORATION
  MESSAGE
  TOOL
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum OrderType {
  MEMBERSHIP
  WORKFLOW_PURCHASE
  COLLABORATION_DEPOSIT
  CUSTOM
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  REFUNDED
  FAILED
}

enum PaymentMethod {
  WECHAT_PAY
  ALIPAY
  STRIPE
  MANUAL
}

enum WorkflowItemStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  ARCHIVED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ═════════════════════════════════════════════════════════════════
//                           User & Auth
// ═════════════════════════════════════════════════════════════════

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  name         String
  avatar       String?
  bio          String?
  passwordHash String     @map("password_hash")
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)

  // 个人主页字段
  industryRole   String?  @map("industry_role")            // 行业角色，例如 "导演 / 编剧"
  expertise      String[] @default([])                     // 擅长领域
  favoriteTools  String[] @default([]) @map("favorite_tools") // 常用 AI 视频工具
  portfolioLinks String[] @default([]) @map("portfolio_links")
  contact        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 社区关系
  ownedChannels      Channel[]       @relation("ChannelOwner")
  channelMemberships ChannelMember[]
  posts              Post[]
  comments           Comment[]
  works              Work[]
  collaborations     Collaboration[]
  toolsContributed   Tool[]          @relation("ToolContributor")

  // 私信
  conversations ConversationParticipant[]
  messagesSent  Message[]                 @relation("MessageSender")

  // 互动
  likes     Like[]
  bookmarks Bookmark[]

  // 通知 / 举报 / 审计
  notificationsReceived  Notification[] @relation("NotificationRecipient")
  notificationsTriggered Notification[] @relation("NotificationActor")
  reportsFiled           Report[]       @relation("ReportReporter")
  reportsResolved        Report[]       @relation("ReportResolver")
  auditLogs              AuditLog[]     @relation("AuditAdmin")

  // 商业化扩展
  subscriptions           Subscription[]
  orders                  Order[]
  workflowItemsAsSeller   WorkflowItem[]       @relation("WorkflowItemSeller")
  organizationMemberships OrganizationMember[]

  @@index([status])
  @@index([role])
  @@map("users")
}

// ═════════════════════════════════════════════════════════════════
//                            Community
// ═════════════════════════════════════════════════════════════════

model Channel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  banner      String?
  color       String   @default("#3b82f6")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   User            @relation("ChannelOwner", fields: [ownerId], references: [id])
  members ChannelMember[]
  posts   Post[]

  @@map("channels")
}

model ChannelMember {
  channelId String   @map("channel_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

// ═════════════════════════════════════════════════════════════════
//                              Posts
// ═════════════════════════════════════════════════════════════════

model Post {
  id            String   @id @default(cuid())
  channelId     String   @map("channel_id")
  authorId      String   @map("author_id")
  title         String
  content       String
  type          PostType @default(DISCUSSION)
  videoUrl      String?  @map("video_url")
  imageUrl      String?  @map("image_url")
  views         Int      @default(0)
  likeCount     Int      @default(0) @map("like_count")
  commentCount  Int      @default(0) @map("comment_count")
  bookmarkCount Int      @default(0) @map("bookmark_count")
  pinned        Boolean  @default(false)
  locked        Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]

  @@index([channelId, createdAt])
  @@index([authorId])
  @@index([type])
  @@map("posts")
}

// ═════════════════════════════════════════════════════════════════
//                            Comments
// ═════════════════════════════════════════════════════════════════

model Comment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String
  likeCount Int      @default(0) @map("like_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")
  likes   Like[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("comments")
}

// ═════════════════════════════════════════════════════════════════
//                         Works (作品广场)
// ═════════════════════════════════════════════════════════════════

model Work {
  id            String       @id @default(cuid())
  authorId      String       @map("author_id")
  title         String
  description   String?
  videoUrl      String       @map("video_url")
  thumbnailUrl  String?      @map("thumbnail_url")
  category      WorkCategory @default(STORY)
  tools         String[]     @default([])
  model         WorkModel    @default(SEEDANCE_2_0)
  mode          WorkMode     @default(TEXT_TO_VIDEO)
  prompt        String?
  durationSec   Int?         @map("duration_sec")
  resolution    String?
  ratio         String?
  views         Int          @default(0)
  likeCount     Int          @default(0) @map("like_count")
  bookmarkCount Int          @default(0) @map("bookmark_count")
  isPublic      Boolean      @default(true) @map("is_public")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  bookmarks Bookmark[]

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
  @@map("works")
}

// ═════════════════════════════════════════════════════════════════
//                  Collaboration (项目合作 / 接单)
// ═════════════════════════════════════════════════════════════════

model Collaboration {
  id          String                @id @default(cuid())
  authorId    String                @map("author_id")
  title       String
  description String
  type        CollaborationType     @default(LOOKING_FOR)
  category    CollaborationCategory @default(OTHER)
  workMode    CollaborationWorkMode @default(PROJECT) @map("work_mode")
  location    CollaborationLocation @default(REMOTE)
  status      CollaborationStatus   @default(OPEN)
  budget      String?
  contact     String?
  deadline    DateTime?
  tags        String[]
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([category])
  @@index([type])
  @@map("collaborations")
}

// ═════════════════════════════════════════════════════════════════
//                Tools (AI 视频工具库) + Workflow Market
// ═════════════════════════════════════════════════════════════════

model Tool {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  url         String
  category    String
  useCase     String?     @map("use_case")
  logoUrl     String?     @map("logo_url")
  pricing     ToolPricing @default(FREE)
  tags        String[]
  isOfficial  Boolean     @default(false) @map("is_official")
  createdById String?     @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  createdBy User? @relation("ToolContributor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category])
  @@map("tools")
}

/// 工作流商品（用户可上架/售卖 ComfyUI / 节点图 / Prompt 包等）
model WorkflowItem {
  id          String             @id @default(cuid())
  sellerId    String             @map("seller_id")
  title       String
  description String
  coverUrl    String?            @map("cover_url")
  downloadUrl String?            @map("download_url")
  priceCents  Int                @default(0) @map("price_cents")
  currency    String             @default("CNY")
  category    String
  tags        String[]           @default([])
  toolStack   String[]           @default([]) @map("tool_stack")
  salesCount  Int                @default(0) @map("sales_count")
  status      WorkflowItemStatus @default(DRAFT)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  seller User    @relation("WorkflowItemSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([sellerId])
  @@index([status, createdAt])
  @@index([category])
  @@map("workflow_items")
}

// ═════════════════════════════════════════════════════════════════
//                  Messaging (一对一 / 群聊 私信)
// ═════════════════════════════════════════════════════════════════

model Conversation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  lastMessageAt DateTime @default(now()) @map("last_message_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ═════════════════════════════════════════════════════════════════
//                   Engagement (点赞 / 收藏)
// ═════════════════════════════════════════════════════════════════

/// 多态点赞：post / work / comment 三选一，由可空外键 + DB 唯一约束保证
model Like {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  workId    String?  @map("work_id")
  commentId String?  @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  work    Work?    @relation(fields: [workId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, workId])
  @@unique([userId, commentId])
  @@map("likes")
}

/// 多态收藏：post / work 二选一
model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  workId    String?  @map("work_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  work Work? @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, workId])
  @@map("bookmarks")
}

// ═════════════════════════════════════════════════════════════════
//             Notification / Report / AuditLog (管理后台)
// ═════════════════════════════════════════════════════════════════

model Notification {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  type       NotificationType
  title      String
  body       String?
  link       String?
  actorId    String?          @map("actor_id")
  targetType String?          @map("target_type")
  targetId   String?          @map("target_id")
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Report {
  id           String           @id @default(cuid())
  reporterId   String           @map("reporter_id")
  targetType   ReportTargetType @map("target_type")
  targetId     String           @map("target_id")
  reason       String
  description  String?
  status       ReportStatus     @default(PENDING)
  resolvedById String?          @map("resolved_by_id")
  resolvedAt   DateTime?        @map("resolved_at")
  resolution   String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  reporter   User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("reports")
}

/// 后台管理员操作审计；action 用大写下划线字符串（如 "DELETE_POST" / "BAN_USER"）
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String   @map("admin_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// ═════════════════════════════════════════════════════════════════
//      Commerce (会员 / 订阅 / 订单) — 商业化扩展 stub
// ═════════════════════════════════════════════════════════════════

model MembershipPlan {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  priceCents  Int          @map("price_cents")
  currency    String       @default("CNY")
  cycle       BillingCycle @default(MONTHLY)
  features    String[]     @default([])
  isActive    Boolean      @default(true) @map("is_active")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  subscriptions Subscription[]
  orders        Order[]

  @@map("membership_plans")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @map("user_id")
  planId           String             @map("plan_id")
  status           SubscriptionStatus @default(ACTIVE)
  startedAt        DateTime           @default(now()) @map("started_at")
  currentPeriodEnd DateTime           @map("current_period_end")
  canceledAt       DateTime?          @map("canceled_at")
  externalId       String?            @map("external_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model Order {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  orderNo        String         @unique @map("order_no")
  type           OrderType
  status         OrderStatus    @default(PENDING)
  amountCents    Int            @map("amount_cents")
  currency       String         @default("CNY")
  planId         String?        @map("plan_id")
  workflowItemId String?        @map("workflow_item_id")
  paymentMethod  PaymentMethod? @map("payment_method")
  paidAt         DateTime?      @map("paid_at")
  refundedAt     DateTime?      @map("refunded_at")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         MembershipPlan? @relation(fields: [planId], references: [id])
  workflowItem WorkflowItem?   @relation(fields: [workflowItemId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([type])
  @@map("orders")
}

// ═════════════════════════════════════════════════════════════════
//                  Organization (企业账号) stub
// ═════════════════════════════════════════════════════════════════

model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  logo        String?
  website     String?
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members OrganizationMember[]

  @@map("organizations")
}

model OrganizationMember {
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}
